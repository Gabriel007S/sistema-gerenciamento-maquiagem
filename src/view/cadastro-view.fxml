<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.*?>

<VBox spacing="10" alignment="CENTER"
	xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controller.CadastroController">

	<GridPane hgap="10" vgap="10" alignment="CENTER">

		<Label text="Nome:" GridPane.rowIndex="0"
			GridPane.columnIndex="0" />
		<TextField fx:id="campoNome" GridPane.rowIndex="0"
			GridPane.columnIndex="1" />

		<Label text="Categoria:" GridPane.rowIndex="1"
			GridPane.columnIndex="0" />
		<ComboBox fx:id="comboCategoria" GridPane.rowIndex="1"
			GridPane.columnIndex="1" />

		<Label text="Preço Compra:" GridPane.rowIndex="2"
			GridPane.columnIndex="0" />
		<TextField fx:id="campoPrecoCompra" GridPane.rowIndex="2"
			GridPane.columnIndex="1" />

		<Label text="Preço Venda:" GridPane.rowIndex="3"
			GridPane.columnIndex="0" />
		<TextField fx:id="campoPrecoVenda" GridPane.rowIndex="3"
			GridPane.columnIndex="1" />

		<Label text="Quantidade:" GridPane.rowIndex="4"
			GridPane.columnIndex="0" />
		<TextField fx:id="campoQuantidade" GridPane.rowIndex="4"
			GridPane.columnIndex="1" />

		<Button text="Cadastrar Produto" onAction="#handleCadastrar"
			GridPane.rowIndex="5" GridPane.columnIndex="1" />

	</GridPane>
</VBox>